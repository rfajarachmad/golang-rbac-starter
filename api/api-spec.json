{
  "openapi": "3.0.3",
  "info": {
    "title": "Go RBAC Starter API",
    "description": "RESTful API built with Go Clean Architecture",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/api/users": {
      "post": {
        "tags": ["User API"],
        "summary": "Register new user",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserWebResponse"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "409": { "description": "Conflict - Email already exists" }
        }
      },
      "delete": {
        "tags": ["User API"],
        "summary": "Logout current user",
        "security": [{ "TokenAuth": [] }],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoolWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/users/_login": {
      "post": {
        "tags": ["User API"],
        "summary": "Login user",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success - Returns token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/users/_current": {
      "get": {
        "tags": ["User API"],
        "summary": "Get current user",
        "security": [{ "TokenAuth": [] }],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "patch": {
        "tags": ["User API"],
        "summary": "Update current user",
        "security": [{ "TokenAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/contacts": {
      "get": {
        "tags": ["Contact API"],
        "summary": "Search contacts",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "name", "in": "query", "schema": { "type": "string" } },
          { "name": "email", "in": "query", "schema": { "type": "string" } },
          { "name": "phone", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactListWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Contact API"],
        "summary": "Create contact",
        "security": [{ "TokenAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactWebResponse"
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/contacts/{contactId}": {
      "get": {
        "tags": ["Contact API"],
        "summary": "Get contact",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      },
      "put": {
        "tags": ["Contact API"],
        "summary": "Update contact",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      },
      "delete": {
        "tags": ["Contact API"],
        "summary": "Delete contact",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoolWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      }
    },
    "/api/contacts/{contactId}/addresses": {
      "get": {
        "tags": ["Address API"],
        "summary": "List addresses",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddressListWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Contact Not Found" }
        }
      },
      "post": {
        "tags": ["Address API"],
        "summary": "Create address",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAddressRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddressWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Contact Not Found" }
        }
      }
    },
    "/api/contacts/{contactId}/addresses/{addressId}": {
      "get": {
        "tags": ["Address API"],
        "summary": "Get address",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "addressId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddressWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      },
      "put": {
        "tags": ["Address API"],
        "summary": "Update address",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "addressId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAddressRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddressWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      },
      "delete": {
        "tags": ["Address API"],
        "summary": "Delete address",
        "security": [{ "TokenAuth": [] }],
        "parameters": [
          { "name": "contactId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "addressId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BoolWebResponse"
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not Found" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "TokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token from login response"
      }
    },
    "schemas": {
      "RegisterUserRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string", "maxLength": 100 },
          "email": { "type": "string", "format": "email", "maxLength": 100 },
          "password": { "type": "string", "maxLength": 100 }
        }
      },
      "LoginUserRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 100 },
          "password": { "type": "string", "maxLength": 100 }
        }
      },
      "CreateContactRequest": {
        "type": "object",
        "required": ["first_name"],
        "properties": {
          "first_name": { "type": "string", "maxLength": 100 },
          "last_name": { "type": "string", "maxLength": 100 },
          "email": { "type": "string", "format": "email", "maxLength": 100 },
          "phone": { "type": "string", "maxLength": 100 }
        }
      },
      "UpdateContactRequest": {
        "type": "object",
        "required": ["first_name"],
        "properties": {
          "first_name": { "type": "string", "maxLength": 100 },
          "last_name": { "type": "string", "maxLength": 100 },
          "email": { "type": "string", "format": "email", "maxLength": 100 },
          "phone": { "type": "string", "maxLength": 100 }
        }
      },
      "CreateAddressRequest": {
        "type": "object",
        "properties": {
          "street": { "type": "string", "maxLength": 255 },
          "city": { "type": "string", "maxLength": 100 },
          "province": { "type": "string", "maxLength": 100 },
          "postal_code": { "type": "string", "maxLength": 20 },
          "country": { "type": "string", "maxLength": 100 }
        }
      },
      "UpdateAddressRequest": {
        "type": "object",
        "properties": {
          "street": { "type": "string", "maxLength": 255 },
          "city": { "type": "string", "maxLength": 100 },
          "province": { "type": "string", "maxLength": 100 },
          "postal_code": { "type": "string", "maxLength": 20 },
          "country": { "type": "string", "maxLength": 100 }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "token": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ContactResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "AddressResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "street": { "type": "string" },
          "city": { "type": "string" },
          "province": { "type": "string" },
          "postal_code": { "type": "string" },
          "country": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "PageMetadata": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "size": { "type": "integer" },
          "total_item": { "type": "integer" },
          "total_page": { "type": "integer" }
        }
      },
      "UserWebResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/UserResponse" },
          "errors": { "type": "string" }
        }
      },
      "ContactWebResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/ContactResponse" },
          "errors": { "type": "string" }
        }
      },
      "ContactListWebResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/ContactResponse" } },
          "paging": { "$ref": "#/components/schemas/PageMetadata" },
          "errors": { "type": "string" }
        }
      },
      "AddressWebResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/AddressResponse" },
          "errors": { "type": "string" }
        }
      },
      "AddressListWebResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/AddressResponse" } },
          "errors": { "type": "string" }
        }
      },
      "BoolWebResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "boolean" },
          "errors": { "type": "string" }
        }
      }
    }
  }
}
